# Canonical host: force HTTPS and strip www. Both www and non-www served the
# full site, creating a duplicate-content split (canonical/hreflang point to the
# non-www host) and silently CORS-blocking the /kits voting on www. This 301s
# every www or http request to https://myworldcupguide.com, preserving the path.
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^ https://myworldcupguide.com%{REQUEST_URI} [R=301,L]

# 2026-06-03: We rebuilt the 104-match schedule against FIFA's official fixture
# list . the previous data had wrong home/away assignments and match numbers, so
# old match URLs (e.g. /matches/mexico-vs-south-korea-1/) no longer exist. 301
# any 404'd /matches/<slug>/ to /schedule/ so inbound links don't bounce.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} ^/matches/[^/]+/?$
RewriteRule ^matches/[^/]+/?$ /schedule/ [R=301,L]
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php84” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php84___lsphp .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
